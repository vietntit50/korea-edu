# Staging — copy to .env and fill secrets from Meta Developer Console
# cp .env.staging.example .env

DATABASE_URL=jdbc:postgresql://localhost:5432/korea_edu_chatbot
DATABASE_USERNAME=chatbot
DATABASE_PASSWORD=chatbot
SERVER_PORT=8080

# Must match Verify Token entered in Meta → Messenger → Webhooks
FACEBOOK_VERIFY_TOKEN=korea-edu-staging-verify-2026

# App → Settings → Basic → App Secret
FACEBOOK_APP_SECRET=

# Messenger → Settings → Page Access Token
FACEBOOK_PAGE_ACCESS_TOKEN=

FACEBOOK_GRAPH_API_VERSION=v21.0
FACEBOOK_SIGNATURE_VERIFICATION_ENABLED=true
MESSENGER_SEND_ENABLED=true
